{
    "build": {
        "target": ".",
        "tasks": [
            { "for": "java", "src": "srv" },
            { "for": "ord", "src": "srv", "dest": "srv/src/main/resources/ord" }
        ]
    },
    "ord": {
        "namespace": "customer.sample",
        "description": "this is my java example description",
        "policyLevels": ["sap:core:v1"],
        "customOrdContentFile": "./ord/custom.ord.json",
        "existingProductORDId": "sap:product:SAPServiceCloudV2:",
        "products": [
            {
                "ordId": "customer:product:eb.bm.tests:",
                "vendor": "sap:vendor:SAP:"
            }
        ],
        "packages": [
            {
                "vendor": "sap:vendor:SAP:"
            }
        ]
    }
}
